# Provider credentials only. Keep model choices in reviews/model-panels.json,
# checks/suite.json, task configs, or command-line flags.

# Lightning AI Model APIs.
LIGHTNING_API_KEY=

# Optional billing suffix appended to LIGHTNING_API_KEY when the key does not
# already include one. Examples: my-username/research or my-org/general.
LIGHTNING_BILLING_SCOPE=

# OpenRouter fallback or comparison provider.
OPENROUTER_API_KEY=

# Custom OpenAI-compatible provider.
MODEL_API_BASE_URL=
MODEL_API_KEY=
MODEL_API_PROVIDER_NAME=
